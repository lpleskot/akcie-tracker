{
  "name": "akcie-tracker-flex-import",
  "version": "1.0.0",
  "private": true,
  "description": "Cron worker pro automatický import obchodů a transakcí z IBKR Flex Web Service.",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev --test-scheduled",
    "tail": "wrangler tail",
    "trigger": "curl -X POST 'https://cloudflare.com/cdn-cgi/mf/scheduled?cron=*+*+*+*+*' "
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
